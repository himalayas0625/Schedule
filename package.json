{
  "name": "screen-schedule",
  "version": "1.0.17",
  "description": "Desktop floating week schedule overlay",
  "author": "screen-schedule",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always",
    "lint": "eslint src/ -c eslint.config.mjs",
    "lint:fix": "eslint src/ --fix -c eslint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.schedule.widget",
    "productName": "Schedule",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/.claude{,/**/*}",
      "!test{,/**/*}",
      "!CLAUDE.md",
      "!PRD.md",
      "!README.md",
      "!RELEASE-NOTES.md",
      "!skills-lock.json",
      "!vitest.config.js",
      "!eslint.config.mjs"
    ],
    "extraResources": [
      {
        "from": "logo.png",
        "to": "logo.png"
      },
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "himalayas0625",
      "repo": "Schedule",
      "releaseType": "release"
    },
    "releaseInfo": {
      "releaseNotesFile": "RELEASE-NOTES.md"
    }
  }
}
