{
  "name": "screen-schedule",
  "version": "1.0.0",
  "description": "Desktop floating week schedule overlay",
  "author": "screen-schedule",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.schedule.widget",
    "productName": "Schedule",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "logo.png", "to": "logo.png" }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "himalayas0625",
      "repo": "Schedule"
    }
  }
}
